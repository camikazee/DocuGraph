# DocuGraph — Portainer stack environment variables.
# Paste these into Portainer → Stack → "Environment variables" (or upload this
# file). Fill the REQUIRED ones; the rest have sensible defaults.
#
# Generate secrets:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"

# ── REQUIRED ────────────────────────────────────────────────────────────────
# Long, random, unique. MEDIA_SECRET encrypts volume creds + Git remotes and
# MUST stay stable forever (rotating it makes encrypted data unreadable).
JWT_SECRET=change-me-long-random
MEDIA_SECRET=change-me-different-long-random

# Public URLs. NEXT_PUBLIC_API_URL is baked into the frontend at build time and
# must be the API URL the browser calls. APP_URL is the public frontend URL
# (used in emails + OAuth redirect + share links). CORS_ORIGINS = exact origin.
NEXT_PUBLIC_API_URL=https://api.docs.example.com/api/v1
APP_URL=https://docs.example.com
CORS_ORIGINS=https://docs.example.com

# ── Host port mapping (only needed if not behind a reverse proxy) ────────────
BACKEND_PORT=3000
FRONTEND_PORT=3002

# ── Optional ─────────────────────────────────────────────────────────────────
JWT_EXPIRES_IN=1d
SWAGGER_ENABLED=false

# SMTP (leave SMTP_HOST empty to log emails instead of sending)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=DocuGraph <no-reply@docugraph.local>

# OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://api.docs.example.com/api/v1/auth/github/callback
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_CALLBACK_URL=https://api.docs.example.com/api/v1/auth/slack/callback

# Rate limiting (optional overrides)
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
AUTH_THROTTLE_TTL_MS=60000
AUTH_THROTTLE_LIMIT=10
