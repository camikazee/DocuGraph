# --- Application ---
NODE_ENV=development
PORT=3000

# --- Database ---
# Local docker-compose Mongo:
MONGO_URI=mongodb://localhost:27017/docugraph

# --- Auth (JWT) ---
# Use a long random string in production (min 16 chars). Generate e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=1d

# --- GitHub OAuth (optional; enables "Continue with GitHub") ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/api/v1/auth/github/callback

# --- Slack OAuth (optional) ---
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_CALLBACK_URL=http://localhost:3000/api/v1/auth/slack/callback

# --- Security tunables ---
BCRYPT_ROUNDS=12
INVITE_TOKEN_TTL_HOURS=72
PASSWORD_RESET_TTL_HOURS=1

# --- Secret encryption (media volume credentials, Git push remote) ---
# Dedicated key for AES-256-GCM encryption of stored secrets. If unset it
# falls back to JWT_SECRET; set a separate long random value in production.
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
MEDIA_SECRET=

# --- App URL (used to build links in emails, e.g. password reset) ---
APP_URL=http://localhost:3002

# --- API docs (Swagger at /api/docs) — off in production unless set true ---
SWAGGER_ENABLED=false

# --- SMTP (transactional email; leave SMTP_HOST empty to log-only in dev) ---
# Dev: the docker-compose stack ships Mailpit (inbox at http://localhost:8025).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=DocuGraph <no-reply@docugraph.local>

# --- CORS ---
# '*' to allow all, or a comma-separated list of allowed origins:
# CORS_ORIGINS=https://app.example.com,https://docs.example.com
CORS_ORIGINS=*

# --- Rate limiting (per IP) ---
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
# Ostrzejszy limit dla endpointów auth (login/register/forgot/reset).
AUTH_THROTTLE_TTL_MS=60000
AUTH_THROTTLE_LIMIT=10

# --- Documents storage ---
# Base directory for .md files (filesystem is the source of truth).
WORKSPACE_ROOT=./workspaces
